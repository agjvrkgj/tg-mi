# 从 https://my.telegram.org 获取
TG_API_ID=123456
TG_API_HASH=your_api_hash

# 源频道：可写 @username、公开链接用户名，或 -100 开头频道 ID；多个用英文逗号分隔
TG_SOURCE_CHANNELS=@source_channel_1,@source_channel_2

# 目标频道：机器人/账号必须是目标频道管理员并有发消息权限
TG_TARGET_CHANNEL=@target_channel

# 可选：仅搬运视频；设为 true 时相册中的图片也会一起搬运
TG_INCLUDE_PHOTOS=false

# 可选：下载目录使用磁盘目录，不要放到 /dev/shm 这类 tmpfs 内存盘
TG_DOWNLOAD_DIR=./tg_mirror_tmp

# 可选：相册等待秒数、上传超时秒数、视频上传前删除开头秒数
TG_ALBUM_WAIT=3
TG_UPLOAD_TIMEOUT=1800
TG_TRIM_VIDEO_SECONDS=10
